import os
import sys
import argparse
import subprocess

def main():
    parser = argparse.ArgumentParser(
        description="CPTPP Generic Toolchain Driver",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""Examples:
  ./cptpp -E scripts/csv_cleaner.py data/raw.csv -o data/clean.csv
  ./cptpp -emit-ml scripts/parse_hs.py data/clean.csv -o ir/hs.ml
  ./cptpp -c ir/serialize_hs.exe ir/hs.ml -o bin/hs.bin
        """
    )
    
    group = parser.add_mutually_exclusive_group(required=True)
    group.add_argument("-E", "--preprocess", action="store_true", help="Run a preprocessing/cleaning script")
    group.add_argument("-emit-ml", "--generate-ml", action="store_true", help="Run an OCaml generator script")
    group.add_argument("-c", "--compile", action="store_true", help="Run an OCaml binary serializer")

    parser.add_argument("processor", help="Path to the script or executable performing the phase")
    parser.add_argument("input_file", help="Path to the input file")
    parser.add_argument("-o", "--output", required=True, help="Path to the output file")

    args = parser.parse_args()

    if not os.path.exists(args.processor):
        print(f"cptpp: error: processor not found: '{args.processor}'", file=sys.stderr)
        sys.exit(1)
    if not os.path.exists(args.input_file):
        print(f"cptpp: error: input file not found: '{args.input_file}'", file=sys.stderr)
        sys.exit(1)

    print(f"cptpp: Executing phase with {args.processor}...")

    try:
        if args.processor.endswith(".py"):
            cmd = [sys.executable, args.processor, args.input_file, "-o", args.output]
        else:
            cmd = [args.processor, args.input_file, "-o", args.output]

        subprocess.run(cmd, check=True)
        print(f"cptpp: Phase successful -> {args.output}")

    except subprocess.CalledProcessError as e:
        print(f"cptpp: error: Phase failed inside {args.processor}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()